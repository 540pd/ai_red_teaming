# Copy to .env and fill in real values. NEVER commit .env.
#
# The chat endpoint under test.
# Defaults below point at the bundled mock (examples/mock_endpoint.py) so you can
# verify the plumbing immediately. Replace with your real endpoint for actual runs.
TARGET_CHAT_URL=http://127.0.0.1:8811/chat
TARGET_CHAT_API_KEY=test-key-123

