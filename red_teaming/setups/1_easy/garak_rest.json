{
  "rest": {
    "RestGenerator": {
      "name": "chat_endpoint",
      "uri": "$TARGET_CHAT_URL",
      "method": "post",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer $TARGET_CHAT_API_KEY"
      },
      "req_template_json_object": {
        "messages": [
          { "role": "user", "content": "$INPUT" }
        ]
      },
      "response_json": true,
      "response_json_field": "$.choices[0].message.content"
    }
  }
}
